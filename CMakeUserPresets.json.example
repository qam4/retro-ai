{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev-mingw",
      "inherits": "ci-mingw",
      "binaryDir": "${sourceDir}/build/dev-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "C:/src/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic",
        "VCPKG_HOST_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "dev-win64",
      "inherits": "ci-windows",
      "binaryDir": "${sourceDir}/build/dev-win64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "C:/src/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-mingw",
      "configurePreset": "dev-mingw",
      "jobs": 8
    },
    {
      "name": "dev-win64",
      "configurePreset": "dev-win64",
      "configuration": "Debug",
      "jobs": 8
    }
  ],
  "testPresets": [
    {
      "name": "dev-mingw",
      "configurePreset": "dev-mingw",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-win64",
      "configurePreset": "dev-win64",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
